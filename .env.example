# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your real values:
#     cp .env.example .env
#
# NEVER commit your real ".env" — it holds your PIN, personal details, and the
# target site. ".env" is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Date / time ───────────────────────────────────────────────────────────────
# Days ahead of the open-time to target (default 14).
DAYS_AHEAD=14
# Time the booking window opens each night (HH:MM, Asia/Manila).
OPEN_TIME=00:00
# How many ms before OPEN_TIME to wake up and pre-select (default 3 min).
PRE_OPEN_MS=180000

# ── Target site ───────────────────────────────────────────────────────────────
# The scheduling page to automate and its resource/grid identifiers.
BOOKING_BASE_URL=https://example.com/step2.php
BOOKING_FACILITY=facility
PRIMARY_RESOURCE=Resource 1
SALE_RESOURCE_1=Resource 2
SALE_RESOURCE_2=Resource 3
# Price text shown on a discounted 4pm cell that triggers "promo" mode.
SALE_PRICE=100.00

# ── Payment ───────────────────────────────────────────────────────────────────
# Category button (e.g. "E-Wallets") and the specific option label.
PAYMENT_CATEGORY=E-Wallets
PAYMENT_LABEL=Wallet
# Your 6-digit wallet PIN. Stored locally only — never logged or committed.
WALLET_PIN=000000

# ── Booker details ────────────────────────────────────────────────────────────
BOOKER_NAME=Your Name
BOOKER_PHONE=09XXXXXXXXX
BOOKER_EMAIL=you@example.com

# ── Behaviour ─────────────────────────────────────────────────────────────────
# false = show browser window (recommended)
HEADLESS=false
# Retry delay in ms when nothing is free yet at pre-select time.
RETRY_MS=400
# Optional webhook URL for phone notifications (ntfy.sh / Discord / Telegram).
NOTIFY_WEBHOOK=

# ── Test mode (npm run test-book) ─────────────────────────────────────────────
# Any booking page URL to dry-run slot selection against.
TEST_URL=https://example.com/step2.php?facility=facility&date=2026-01-01
# Seconds from now to simulate the open moment (shows countdown).
FIRE_IN_SECONDS=10
# Dummy PIN used in test mode — never your real one.
TEST_WALLET_PIN=00000
